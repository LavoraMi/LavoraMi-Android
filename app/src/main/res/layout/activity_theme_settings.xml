<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    tools:context=".ThemeSettings">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/backBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@color/background_app"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_back"
            app:tint="?attr/colorControlNormal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/appearance"
            android:fontFamily="@font/work_sans_medium"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/favoritesSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:fontFamily="@font/work_sans_medium"
                    android:paddingBottom="5dp"
                    android:text="@string/themeDeps"
                    android:textColor="#8E8E93"
                    android:textSize="18sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/disclosureBg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:id="@+id/system"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/iconSystem"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_setting"
                                app:tint="@color/redMetro"
                                android:visibility="visible"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:fontFamily="@font/inter_medium"
                                android:layout_marginStart="16dp"
                                android:text="@string/sistemaTheme"
                                android:layout_toEndOf="@id/iconSystem"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp" />

                            <ImageView
                                android:id="@+id/checkSystem"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/check"
                                app:tint="@color/redMetro"
                                android:visibility="visible"/>
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginStart="60dp"
                            android:background="#38383A" />

                        <RelativeLayout
                            android:id="@+id/dark"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/iconDark"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_dark"
                                app:tint="@color/redMetro"
                                android:visibility="visible"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/iconDark"
                                android:text="@string/darkTheme"
                                android:fontFamily="@font/inter_medium"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp" />

                            <ImageView
                                android:id="@+id/checkDark"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/check"
                                app:tint="@color/redMetro"
                                android:visibility="gone"/>
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginStart="60dp"
                            android:background="#38383A" />

                        <RelativeLayout
                            android:id="@+id/light"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/iconLight"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_light"
                                app:tint="@color/redMetro"
                                android:visibility="visible"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:text="@string/lightTheme"
                                android:fontFamily="@font/inter_medium"
                                android:layout_toEndOf="@id/iconLight"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp" />

                            <ImageView
                                android:id="@+id/checkLight"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/check"
                                app:tint="@color/redMetro"
                                android:visibility="gone"/>
                        </RelativeLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/infoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/inter_medium"
                    android:text="@string/themeDisclaimer"
                    android:textColor="#8E8E93"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/languageSelection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:paddingBottom="5dp"
                    android:fontFamily="@font/work_sans_medium"
                    android:text="@string/languageDeps"
                    android:textColor="#8E8E93"
                    android:textSize="18sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/disclosureBg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:id="@+id/italian"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/iconItaly"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_italy"
                                android:visibility="visible"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:fontFamily="@font/inter_medium"
                                android:layout_toEndOf="@id/iconItaly"
                                android:layout_marginStart="10dp"
                                android:text="@string/italianSettings"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp"/>

                            <ImageView
                                android:id="@+id/checkItalian"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/check"
                                app:tint="@color/redMetro"
                                android:visibility="visible"/>
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginStart="60dp"
                            android:background="#38383A" />

                        <RelativeLayout
                            android:id="@+id/english"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/iconGB"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_uk"
                                android:visibility="visible"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_toEndOf="@id/iconGB"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/inter_medium"
                                android:text="@string/englishLanguage"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp" />

                            <ImageView
                                android:id="@+id/checkEnglish"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/check"
                                app:tint="@color/redMetro"
                                android:visibility="gone"/>
                        </RelativeLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/inter_medium"
                    android:text="@string/themeDisclaimer"
                    android:textColor="#8E8E93"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>