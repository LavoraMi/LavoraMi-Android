<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <LinearLayout
        android:id="@+id/lineDetailPage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="23dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="30dp"
                android:layout_height="27dp"
                android:layout_marginEnd="16dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/outline_arrow_back_ios_new_24"
                app:tint="@color/text_primary" />

            <TextView
                android:id="@+id/detBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="70dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center"
                android:background="@drawable/bg_badge_line"
                android:text=""
                android:textColor="#FFFFFF"
                android:fontFamily="@font/inter_medium"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detTitolo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="15dp"
                android:text=""
                android:textColor="@color/text_primary"
                android:fontFamily="@font/work_sans_medium"
                android:textSize="30sp"
                android:ellipsize="end"
                android:textStyle="bold"
                android:maxLines="1"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/work_sans_medium"
            android:text="@string/linesDirectionsTitle"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="25dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detDirezioni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/deviazioneLinea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/subtitle"
                android:fontFamily="@font/inter_medium"
                android:textSize="12sp"
                android:paddingTop="5dp"
                android:text="@string/tramDeviationsTitle"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/mapDeviationBtn"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_info"
                app:tint="@color/subtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/attestazioneLinea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/subtitle"
            android:fontFamily="@font/inter_medium"
            android:textSize="12sp"
            android:paddingTop="10dp"
            android:text=""
            android:textStyle="bold"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/txtMinutes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/waitingTimeLinesDetails"
            android:fontFamily="@font/work_sans_medium"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="15dp"
            android:textStyle="bold"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/txtInterscambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/interchangeStopLinesDetails"
            android:fontFamily="@font/work_sans_medium"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="15dp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutDetInterscambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iconInterscambio"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ic_train"
                app:tint="@color/text_primary" />

            <TextView
                android:id="@+id/detInterscambio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:text=""
                android:fontFamily="@font/inter_medium"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/detInterscambioEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:text="@string/noInterchangeStationTitle"
            android:fontFamily="@font/inter_medium"
            android:visibility="gone"/>

        <HorizontalScrollView
            android:id="@+id/viewChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupLinee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp"
                android:visibility="gone"/>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/detAttesa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:text=""
            android:fontFamily="@font/inter_medium"
            android:textStyle="bold"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/lineLimitation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/subtitle"
            android:textSize="12sp"
            android:paddingTop="10dp"
            android:text="@string/onlyOnWorkingDaysTitle"
            android:fontFamily="@font/work_sans_medium"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/worksLineDetails"
            android:fontFamily="@font/work_sans_medium"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="15dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detLavori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/titleAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accessibilityTitle"
            android:fontFamily="@font/work_sans_medium"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="15dp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/lineAccessibilityLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_accessibility"
                android:scaleType="fitCenter"
                app:tint="@color/text_primary"/>

            <ImageView
                android:id="@+id/iconAccessibility"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_checkmark"
                app:tint="@color/M2"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/accessibilityText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="Completamente accessibile."
                android:textColor="@color/text_primary"
                android:fontFamily="@font/work_sans_medium"
                android:textSize="18sp"
                android:ellipsize="end"
                android:textStyle="bold"
                android:maxLines="1"/>

            <ImageView
                android:id="@+id/infoIconMetro"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_info"
                app:tint="@color/desc"
                android:contentDescription="Info"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/detActionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMappa"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/mapChip"
                app:chipBackgroundColor="@color/selector_chip_filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLavoriInCorso"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/lineWorksChip"
                app:chipBackgroundColor="@color/selector_chip_filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipInterscambi"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/interchangesChip"
                app:chipBackgroundColor="@color/selector_chip_filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipArrivi"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="Arrivi"
                app:chipBackgroundColor="@color/selector_chip_filter" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="@string/noWorksOnThisLine"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:alpha="0.7"
            android:fontFamily="@font/inter_medium"
            android:visibility="gone" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/mapCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="15dp"
        app:cardBackgroundColor="@color/background_app"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/googleMapsFrameLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:visibility="gone">

            <fragment
                android:id="@+id/map"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/loadingMapsFragmentLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:visibility="visible">

            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp">

                <com.andreafilice.lavorami.DotsLoaderView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_google_maps"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/work_sans_medium"
                android:text="@string/loadingMapDetails"
                android:textAlignment="center"
                android:textColor="@color/text_primary"
                android:textSize="25sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/lavoriSezioneWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="-10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/lavoriNested"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/containerLavori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/interscambiWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="-10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/interscambiNested"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/containerInterscambi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/arriviWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="-10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/arriviNested"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="80dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/stopSelectorLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Scegli una fermata"
                    app:startIconDrawable="@drawable/ic_location"
                    app:boxBackgroundColor="@color/background_app"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdownFermate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/work_sans_medium"/>
                </com.google.android.material.textfield.TextInputLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#1A000000" />

                <ProgressBar
                    android:id="@+id/arriviProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/arriviEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_clock_slash"
                        app:tint="@color/subtitle" />

                    <TextView
                        android:id="@+id/arriviEmptyStateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nessuna corsa disponibile per questa fermata oggi."
                        android:textAlignment="center"
                        android:textColor="@color/subtitle"
                        android:fontFamily="@font/work_sans_medium"
                        android:textSize="16sp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/arriviRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:visibility="visible" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>