<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <LinearLayout
        android:id="@+id/lineDetailPage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="23dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_back"
                app:tint="?attr/colorControlNormal" />

            <TextView
                android:id="@+id/detBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="70dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center"
                android:background="@drawable/bg_badge_line"
                android:text=""
                android:textColor="#FFFFFF"
                android:fontFamily="@font/inter"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detTitolo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:text=""
                android:textColor="@color/text_primary"
                android:fontFamily="@font/inter"
                android:textSize="20sp"
                android:ellipsize="end"
                android:textStyle="bold"
                android:maxLines="1"/>

            <ImageButton
                android:id="@+id/buttonAddInWidget"
                android:layout_width="30dp"
                android:layout_height="27dp"
                android:layout_marginEnd="10dp"
                android:layout_marginStart="5dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_add_line_widget"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/buttonAddLine"
                android:layout_width="30dp"
                android:layout_height="27dp"
                android:layout_marginEnd="10dp"
                android:layout_marginStart="5dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_heart_empty"
                app:tint="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_main"
            android:text="@string/linesDirectionsTitle"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="25dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detDirezioni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:fontFamily="@font/inter"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/deviazioneLinea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_status_banner_warning"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:id="@+id/mapDeviationIcon"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_triangle_warning"
                app:tint="@color/amber_on_banner" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/amber_on_banner"
                android:fontFamily="@font/font_main"
                android:textSize="12sp"
                android:text="@string/tramDeviationsTitle"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/mapDeviationBtn"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_info"
                app:tint="@color/amber_on_banner" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lineaFullBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_status_banner_warning"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_triangle_warning"
                app:tint="@color/amber_on_banner" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/amber_on_banner"
                android:fontFamily="@font/font_main"
                android:textSize="13sp"
                android:text="@string/lineSubBusTitle"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/infoLineBusesBtn"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_info"
                app:tint="@color/amber_on_banner" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/interruzioneTratta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_status_banner_warning"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_triangle_warning"
                app:tint="@color/amber_on_banner" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/amber_on_banner"
                android:fontFamily="@font/font_main"
                android:textSize="13sp"
                android:text="@string/trackInterruptedInfo"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/mapTrackBtn"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_info"
                app:tint="@color/amber_on_banner" />
        </LinearLayout>

        <TextView
            android:id="@+id/attestazioneLinea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/subtitle"
            android:fontFamily="@font/font_main"
            android:textSize="12sp"
            android:paddingTop="10dp"
            android:text=""
            android:textStyle="bold"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/txtMinutes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/waitingTimeLinesDetails"
            android:fontFamily="@font/font_main"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="15dp"
            android:textStyle="bold"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/txtInterscambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/interchangeStopLinesDetails"
            android:fontFamily="@font/font_main"
            android:textColor="@color/subtitle"
            android:textSize="15sp"
            android:layout_marginTop="15dp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutDetInterscambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iconInterscambio"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ic_train"
                app:tint="@color/text_primary" />

            <TextView
                android:id="@+id/detInterscambio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:text=""
                android:fontFamily="@font/inter"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/detInterscambioEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:text="@string/noInterchangeStationTitle"
            android:fontFamily="@font/inter"
            android:visibility="gone"/>

        <HorizontalScrollView
            android:id="@+id/viewChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupLinee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp"
                android:visibility="gone"/>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/detAttesa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:text=""
            android:fontFamily="@font/inter"
            android:textStyle="bold"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/lineLimitation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/subtitle"
            android:textSize="12sp"
            android:paddingTop="10dp"
            android:text="@string/onlyOnWorkingDaysTitle"
            android:fontFamily="@font/font_main"
            android:textStyle="bold" />



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="15dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_triangle_warning"
                app:tint="@color/subtitle"/>

            <TextView
                android:id="@+id/detLavori"
                android:layout_width="0dp"
                android:layout_height="31dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text=""
                android:fontFamily="@font/font_main"
                android:textColor="@color/subtitle"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="2"/>

            <View
                android:layout_width="1dp"
                android:layout_height="31dp"
                android:background="#38383A" />

            <LinearLayout
                android:id="@+id/lineAccessibilityLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginStart="10dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iconDisabile"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_accessibility"
                    app:tint="@color/subtitle"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/iconAccessibility"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_checkmark"
                    app:tint="@color/M2"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/accessibilityText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/fullyAccessible"
                    android:textColor="@color/subtitle"
                    android:fontFamily="@font/font_main"
                    android:textSize="12sp"
                    android:ellipsize="end"
                    android:maxLines="1"/>

                <ImageView
                    android:id="@+id/infoIconMetro"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/subtitle"
                    android:contentDescription="Info"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </LinearLayout>


        <com.google.android.material.chip.ChipGroup
            android:id="@+id/detActionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:singleSelection="true"
            app:singleLine="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMappa"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/mapChip"
                app:chipCornerRadius="50dp"
                app:chipIcon="@drawable/ic_location"
                app:fontFamily="@font/font_main"
                app:chipIconSize="16dp"
                app:ensureMinTouchTargetSize="false"
                app:chipIconVisible="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLavoriInCorso"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/lineWorksChip"
                app:chipCornerRadius="50dp"
                app:chipIcon="@drawable/ic_triangle_warning"
                app:fontFamily="@font/font_main"
                app:chipIconSize="18dp"
                app:ensureMinTouchTargetSize="false"
                app:chipIconVisible="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipInterscambi"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/interchangesChip"
                app:chipCornerRadius="50dp"
                app:chipIcon="@drawable/ic_transfer"
                app:fontFamily="@font/font_main"
                app:chipIconSize="18dp"
                app:ensureMinTouchTargetSize="false"
                app:chipIconVisible="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipArrivi"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:text="@string/arrivalsChipText"
                app:chipCornerRadius="50dp"
                app:chipIcon="@drawable/ic_arrivals"
                app:fontFamily="@font/font_main"
                app:chipIconSize="18dp"
                app:chipIconVisible="true"
                app:ensureMinTouchTargetSize="false"
                android:visibility="gone"/>
        </com.google.android.material.chip.ChipGroup>
        <LinearLayout
            android:id="@+id/emptyViewContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:visibility="gone">

            <ImageView
                android:id="@+id/emptyViewIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_info"
                android:layout_marginTop="3dp"
                app:tint="@color/text_primary"/>

            <TextView
                android:id="@+id/emptyView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/noWorksOnThisLine"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:alpha="0.7"
                android:fontFamily="@font/inter" />

        </LinearLayout>

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/mapCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="15dp"
        app:cardBackgroundColor="@color/background_app"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/googleMapsFrameLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:visibility="gone">

            <com.mapbox.maps.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/txtDirezioneMappa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginTop="34dp"
                android:background="@drawable/glass_bottom_bar_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:elevation="4dp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:text=""
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/lineaRegolareLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/chip_line_bg"
                android:backgroundTint="@color/M2"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/lineaRegolareIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginHorizontal="6dp"
                    android:src="@drawable/ic_checkmark"
                    android:layout_gravity="center_vertical"
                    app:tint="@color/text_primary"/>

                <TextView
                    android:id="@+id/lineRegolareTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:elevation="4dp"
                    android:fontFamily="@font/inter"
                    android:text=""
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="10dp"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/changeRouteButton"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/glass_bottom_bar_bg"
                    android:elevation="4dp"
                    android:src="@drawable/ic_transfer"
                    app:tint="@color/text_primary"
                    android:visibility="gone"/>

                <ImageButton
                    android:id="@+id/positionButton"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:background="@drawable/glass_bottom_bar_bg"
                    android:elevation="4dp"
                    android:src="@drawable/ic_position"
                    app:tint="@color/text_primary" />

            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/loadingMapsFragmentLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:visibility="visible">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/loadingLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toTopOf="@+id/customBottomBar"
                app:layout_constraintTop_toBottomOf="@+id/contentBarrier"
                app:shimmer_auto_start="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <include layout="@layout/loader_map_item" />
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-60dp"
                android:fontFamily="@font/font_main"
                android:text="@string/loadingMapDetails"
                android:textAlignment="center"
                android:textColor="@color/text_primary"
                android:textSize="25sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/lavoriSezioneWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="-10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/lavoriNested"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/containerLavori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/interscambiWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="-10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/interscambiLoadingState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/loaderInterchanges"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toTopOf="@+id/customBottomBar"
                app:layout_constraintTop_toBottomOf="@+id/contentBarrier"
                app:shimmer_auto_start="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/loader_interchanges" />
                    <include layout="@layout/loader_interchanges" />
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectBranch"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:cornerRadius="20dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/subtitle"
            app:backgroundTint="@android:color/transparent"
            android:textColor="@color/text_primary"
            app:iconGravity="textStart"
            app:icon="@drawable/ic_branch_button"
            app:iconSize="16dp"
            app:iconPadding="8dp"
            app:iconTint="@color/text_primary"
            android:visibility="gone" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/interscambiNested"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/containerInterscambi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/arriviWrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/lineDetailPage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/stopSelectorLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/selectAStop"
            app:startIconDrawable="@drawable/ic_location"
            app:boxBackgroundColor="@color/background_app"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxStrokeColor="@color/box_stroke_color"
            app:hintTextColor="@color/text_primary"
            app:endIconTint="@color/BUS"
            app:boxCornerRadiusBottomEnd="10dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/dropdownFermate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/font_main"/>
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#1A000000" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/arriviNested"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <ProgressBar
                    android:id="@+id/arriviProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/arriviEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_clock_slash"
                        app:tint="@color/subtitle" />

                    <TextView
                        android:id="@+id/arriviEmptyStateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/noRoutesToday"
                        android:textAlignment="center"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/font_main"
                        android:textSize="16sp"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:id="@+id/arriviEmptyStateTextSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/noRoutesDeps"
                        android:textAlignment="center"
                        android:textColor="@color/subtitle"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/font_main"
                        android:textSize="12sp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/arriviRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:visibility="visible" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>