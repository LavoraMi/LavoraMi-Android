<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HowAppWorks">

    <ImageView
        android:id="@+id/icon"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="76dp"
        android:layout_marginTop="52dp"
        android:contentDescription="App Icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/appName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="32dp"
        android:fontFamily="@font/archivo_medium"
        android:text="LavoraMi"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/textView4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/icon"
        app:layout_constraintTop_toTopOf="@+id/icon"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:fontFamily="@font/archivo_medium"
        android:text="@string/howAppWorks"
        android:textColor="#999999"
        app:layout_constraintEnd_toEndOf="@+id/appName"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/appName"
        app:layout_constraintTop_toBottomOf="@+id/appName" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="15dp"
        android:background="?android:attr/listDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView4" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/divider"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iconProgressBar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_progress_bar"
                    app:tint="#E41414" />

                <TextView
                    android:id="@+id/progress_bar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/iconProgressBar"
                    android:fontFamily="@font/archivo_medium"
                    android:text="@string/progressBar"
                    android:textColor="#E41414"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textView5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/archivo_medium"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:text="@string/progressBarText"
                    android:textAlignment="center" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    android:layout_below="@+id/textView5"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@color/disclosureBg">
               <RelativeLayout
                   android:layout_width="match_parent"
                   android:layout_height="match_parent">
                    <TextView
                        android:id="@+id/txtStartDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="10dp"
                        android:text="12 Nov 2025"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtEndDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:text="@string/exampleDate1"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="30dp"
                        android:max="100"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:progress="38"
                        android:progressTint="#FD272D" />
                </RelativeLayout>

                </androidx.cardview.widget.CardView>
            </RelativeLayout>
            <View android:layout_width="match_parent"
                android:layout_margin="20dp"
                android:layout_height="1dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:background="#38383A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iconStar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_extension_line"
                    app:tint="#E41414" />

                <TextView
                    android:id="@+id/line_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-1dp"
                    android:layout_toEndOf="@+id/iconStar"
                    android:fontFamily="@font/archivo_medium"
                    android:text="@string/choseLine"
                    android:textColor="#E41414"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/archivo_medium"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:text="@string/choseYourLineText"
                    android:textAlignment="center" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@color/disclosureBg">

            <RelativeLayout
                android:id="@+id/disclosureHeaderMovibus"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="6dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:id="@+id/iconMainMovibus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_bus"
                    app:tint="#E41414" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@+id/iconMainMovibus"
                    android:fontFamily="@font/archivo_medium"
                    android:text="@string/movibusLines"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" />

                <ImageView
                    android:id="@+id/favIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/ic_star_empty"
                    app:tint="#FF9F0A" />
            </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent"
                android:layout_margin="20dp"
                android:layout_height="1dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:background="#38383A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iconInterscambi"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_transfer"
                    app:tint="#E41414" />

                <TextView
                    android:id="@+id/interscambi_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-1dp"
                    android:layout_toEndOf="@+id/iconInterscambi"
                    android:fontFamily="@font/archivo_medium"
                    android:text="@string/viewInterchanges"
                    android:textColor="#E41414"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textView1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/archivo_medium"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:text="@string/viewInterchangesText"
                    android:textAlignment="center" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@color/disclosureBg">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iconEvent"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        app:tint="@color/text_primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:src="@drawable/ic_arrow_left_right" />

                    <TextView
                        android:id="@+id/txtTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Romolo"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/iconEvent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconEvent"
                        app:layout_constraintTop_toTopOf="@id/iconEvent" />

                    <LinearLayout
                        android:id="@+id/layoutSubInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txtTitle">

                        <TextView
                            android:id="@+id/txtLineCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M2"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iconTransport"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_train"
                            app:tint="@color/text_primary"
                             />

                        <TextView
                            android:id="@+id/txtStationSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Romolo"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </LinearLayout>


                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layoutSubInfo">

                        <LinearLayout
                            android:id="@+id/layoutDetInterscambio"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/layoutSubInfo">

                            <TextView
                                android:id="@+id/shimmerLineBadge"
                                android:layout_width="40dp"
                                android:layout_height="26dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:gravity="center"
                                android:textColor="@color/White"
                                android:textStyle="bold"
                                android:text="M2"
                                android:backgroundTint="@color/M2"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/shimmerLineBadge2"
                                android:layout_marginStart="5dp"
                                android:layout_width="42dp"
                                android:layout_height="26dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:backgroundTint="@color/RE80"
                                android:gravity="center"
                                android:text="R31"
                                android:textColor="@color/White"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/shimmerLineBadge3"
                                android:layout_marginStart="5dp"
                                android:layout_width="35dp"
                                android:layout_height="26dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:backgroundTint="@color/S9"
                                android:gravity="center"
                                android:text="S9"
                                android:textColor="@color/White"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/shimmerLineBadge4"
                                android:layout_marginStart="5dp"
                                android:layout_width="42dp"
                                android:layout_height="26dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:backgroundTint="@color/S19"
                                android:gravity="center"
                                android:text="S19"
                                android:textColor="@color/White"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </HorizontalScrollView>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_margin="20dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:background="#38383A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iconCone"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_cone"
                    app:tint="#E41414" />

                <TextView
                    android:id="@+id/cantiere_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-1dp"
                    android:layout_toEndOf="@+id/iconCone"
                    android:fontFamily="@font/archivo_medium"
                    android:text="@string/worksiteStop"
                    android:textColor="#E41414"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textView7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/archivo_medium"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:text="@string/worksiteStopText"
                    android:textAlignment="center" />
            </RelativeLayout>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@color/disclosureBg">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iconRallentamento"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Icon"
                        app:tint="@color/text_primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:src="@drawable/ic_clock_badge" />

                    <TextView
                        android:id="@+id/txtTitle1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/rallentamento"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/iconRallentamento"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconRallentamento"
                        app:layout_constraintTop_toTopOf="@id/iconRallentamento" />

                    <LinearLayout
                        android:id="@+id/layoutSubInfo1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/txtTitle1">

                        <TextView
                            android:id="@+id/txtStationSubtitle1"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="30dp"
                            android:text="Palazzolo, Cammanago Lenate, Seveso"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="@id/iconRallentamento"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/iconRallentamento"
                            app:layout_constraintTop_toTopOf="@id/iconRallentamento" />


                    </LinearLayout>


                    <HorizontalScrollView
                        android:id="@+id/horizontalScrollView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:paddingTop="10dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/layoutSubInfo1">

                        <LinearLayout
                            android:id="@+id/layoutLinee"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/layoutSubInfo1">

                            <TextView
                                android:id="@+id/shimmerLineBadge5"
                                android:layout_width="40dp"
                                android:layout_height="26dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:backgroundTint="@color/S2"
                                android:gravity="center"
                                android:text="S2"
                                android:textColor="@color/White"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/shimmerLineBadge6"
                                android:layout_width="42dp"
                                android:layout_height="26dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:backgroundTint="@color/RE80"
                                android:gravity="center"
                                android:text="R16"
                                android:textColor="@color/White"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/shimmerLineBadge7"
                                android:layout_width="35dp"
                                android:layout_height="26dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/bg_badge_line_shimmer"
                                android:backgroundTint="@color/S4"
                                android:gravity="center"
                                android:text="S4"
                                android:textColor="@color/White"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>


                    </HorizontalScrollView>
                    <RelativeLayout
                        android:id="@+id/progress_layout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:layout_constraintTop_toBottomOf="@+id/horizontalScrollView">
                        <TextView
                            android:id="@+id/txtStartDate1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"

                            android:layout_marginTop="10dp"
                            android:text="23 Feb 2026"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtEndDate1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="10dp"
                            android:text="30 apr 2026"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />

                        <ProgressBar
                            android:id="@+id/progressBar1"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="30dp"
                            android:max="100"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:progress="62"
                            android:progressTint="#FD272D" />
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/textTrenord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/archivo_medium"
                        android:text="Trenord"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        app:layout_constraintTop_toBottomOf="@id/progress_layout"
                        />
                    <TextView
                        android:id="@+id/textView3"
                        android:paddingEnd="10dp"
                        android:paddingStart="10dp"
                        android:textSize="12sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/archivo_medium"
                        android:text="@string/fermataExample"
                        app:layout_constraintTop_toBottomOf="@id/textTrenord"
                       />
                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.cardview.widget.CardView>
            <View android:layout_width="match_parent"
                android:layout_margin="20dp"
                android:layout_height="1dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:background="#38383A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iconBell"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_bell"
                    app:tint="#E41414" />

                <TextView
                    android:id="@+id/update_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-1dp"
                    android:layout_toEndOf="@+id/iconBell"
                    android:fontFamily="@font/archivo_medium"
                    android:text="@string/updateYourself"
                    android:textColor="#E41414"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/textView6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/archivo_medium"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:text="@string/updateYourselfText"
                    android:textAlignment="center" />
            </RelativeLayout>

            <View android:layout_width="match_parent"
                android:layout_margin="20dp"
                android:layout_height="1dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:background="#38383A" />

            <TextView
                android:id="@+id/textDiscalimer"
                android:paddingEnd="10dp"
                android:paddingStart="10dp"
                android:textSize="12sp"
                android:textAlignment="center"
                android:textColor="@color/GRAY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/archivo_medium"
                android:text="@string/disclaimerAppFunctions"

                />
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/backBtn"
        android:layout_width="58dp"
        android:layout_height="43dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="64dp"
        android:background="@color/background_app"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_back"
        app:tint="?attr/colorControlNormal" />
</androidx.constraintlayout.widget.ConstraintLayout>