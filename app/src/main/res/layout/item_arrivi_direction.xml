<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_direction"
            app:tint="@color/subtitle" />

        <TextView
            android:id="@+id/txtDirectionHeadsign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="null"
            android:textColor="@color/subtitle"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/disclosureBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconFirstClock"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clock" />

                <TextView
                    android:id="@+id/txtFirstMins"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text=""
                    android:textSize="32sp"
                    android:fontFamily="@font/inter_medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFirstTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/subtitle"
                    android:textSize="15sp"
                    android:fontFamily="@font/work_sans_medium" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/busDisclaimerBadge"
                android:textColor="@color/subtitle"
                android:textSize="10sp"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/work_sans_medium" />

            <View
                android:id="@+id/dividerArrivi"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A000000"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nextDepartures"
                android:textColor="@color/subtitle"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/work_sans_medium" />

            <LinearLayout
                android:id="@+id/containerOtherDepartures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>