<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/background_app"
        android:paddingTop="23dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="16dp">

        <TextView
            android:id="@+id/mainTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/work_sans_medium"
            android:text="@string/lavoriInCorsoTitle"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            app:layout_constraintWidth_percent="0.7" />

        <ImageButton
            android:id="@+id/buttonRefresh"
            android:layout_width="40dp"
            android:layout_height="37dp"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/mainTextView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/mainTextView"
            app:srcCompat="@drawable/ic_refresh"
            app:tint="@color/redMetro" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/strikeBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/disclosureBg"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/redMetro"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="11dp"
                android:background="@color/RE">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/warning_triangle_filled"
                    app:tint="@android:color/white" />

                <TextView
                    android:id="@+id/strikeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/work_sans_medium"
                    android:text="@string/avvisoSciopero"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />

                <ImageView
                    android:id="@+id/closeBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_close_banner"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@android:color/white" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="9dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:id="@+id/strikeDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Sciopero proclamato per il date"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="9dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="2dp"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:id="@+id/strikeGuaranteed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Le fasce garantite (06:00 - 09:00, 18:00 - 21:00) non sono presenti."
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/GRAY" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_company"
                        app:tint="@color/RE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/work_sans_medium"
                        android:text="@string/strikeBannerAderenti"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/strikeCompanies"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/work_sans_medium"
                        android:text="ATM"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <EditText
        android:id="@+id/editSearch"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@color/background_app"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:hint=""
        android:fontFamily="@font/inter_medium"
        android:inputType="text"
        android:paddingStart="15dp"
        android:textColor="@color/text_primary"
        android:textColorHint="#666666"
        android:imeOptions="actionDone"
        app:layout_constraintTop_toBottomOf="@id/strikeBanner" />

    <TextSwitcher
        android:id="@+id/hintSwitcher"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:isIndicator="true"
        android:layout_marginStart="45dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@id/editSearch"
        app:layout_constraintEnd_toEndOf="@id/editSearch"
        app:layout_constraintStart_toStartOf="@id/editSearch"
        app:layout_constraintTop_toTopOf="@id/editSearch" />

    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="17dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/editSearch">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:selectionRequired="false"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/allFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                app:chipIcon="@drawable/ic_filters"
                app:fontFamily="@font/work_sans_medium"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBus"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bus"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                app:chipIcon="@drawable/ic_bus"
                android:fontFamily="@font/work_sans_medium"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTram"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tram"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                android:fontFamily="@font/work_sans_medium"
                app:chipIcon="@drawable/ic_tram"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMetro"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/metroFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                android:fontFamily="@font/work_sans_medium"
                app:chipIcon="@drawable/ic_metro"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTreno"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trainFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                android:fontFamily="@font/work_sans_medium"
                app:chipIcon="@drawable/ic_train"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipInCorso"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lavoriInCorso"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                android:fontFamily="@font/work_sans_medium"
                app:chipIcon="@drawable/ic_incorso"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipProgrammati"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scheduledFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter"
                android:fontFamily="@font/work_sans_medium"
                app:chipIcon="@drawable/ic_calendar"
                app:chipIconSize="18dp"
                app:chipIconTint="@color/text_primary"
                app:chipIconVisible="true"
                app:iconStartPadding="10dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipATM"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/atmFilter"
                android:fontFamily="@font/work_sans_medium"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTrenord"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/work_sans_medium"
                android:text="@string/trenordFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMovibus"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/work_sans_medium"
                android:text="@string/movibusFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStav"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/work_sans_medium"
                android:text="@string/stavFilter"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAutoguidovie"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/autoguidovieFilter"
                android:fontFamily="@font/work_sans_medium"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/selector_chip_filter" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/emptyView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/work_sans_medium"
        android:text="@string/noWorkOnFilter"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/recyclerView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/recyclerView" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/customBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filterScroll" />

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/customBottomBar"
        app:layout_constraintTop_toBottomOf="@+id/filterScroll"
        app:shimmer_auto_start="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <include layout="@layout/item_lavoro" />
            <include layout="@layout/item_lavoro" />
            <include layout="@layout/item_lavoro" />
            <include layout="@layout/item_lavoro" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <LinearLayout
        android:id="@+id/errorNetwork"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/customBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout">

        <ImageView
            android:id="@+id/iconWifi"
            android:layout_width="88dp"
            android:layout_height="59dp"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/work_sans_medium"
            android:text="@string/downloadDataError"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:fontFamily="@font/work_sans_medium"
            android:text="@string/noInternetConnectionError"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnRefreshOnError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/redMetro"
            android:text="@string/retry"
            android:textColor="@color/White"
            app:icon="@drawable/ic_refresh"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/White" />

        <TextView
            android:id="@+id/errorDeps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="30dp"
            android:fontFamily="@font/work_sans_medium"
            android:text="_message"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/customBottomBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/background_app"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_home"
            app:tint="#FD272D" />

        <ImageButton
            android:id="@+id/linesButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_branch"
            app:tint="?attr/colorControlNormal" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_setting"
            app:tint="?attr/colorControlNormal" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/setupOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_app"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        tools:visibility="gone">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/setupViewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@+id/setupActionContainer"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/setupIndicator"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:layout_marginBottom="24dp"
            android:background="@android:color/transparent"
            app:layout_constraintBottom_toTopOf="@+id/setupActionContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tabBackground="@drawable/selector_dot_indicator"
            app:tabGravity="center"
            app:tabIndicatorHeight="0dp"
            app:tabMaxWidth="24dp"
            app:tabMinWidth="24dp"
            app:tabMode="fixed"
            app:tabPaddingBottom="0dp"
            app:tabPaddingEnd="8dp"
            app:tabPaddingStart="8dp"
            app:tabPaddingTop="0dp"
            app:tabRippleColor="@android:color/transparent" />

        <LinearLayout
            android:id="@+id/setupActionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetupNext"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#FD272D"
                android:fontFamily="@font/work_sans_medium"
                android:text="@string/next"
                android:textAllCaps="false"
                android:textColor="@color/White"
                android:textSize="18sp"

                app:cornerRadius="12dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgSetupSkip"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="55dp"
            android:layout_marginEnd="-18dp"
            android:src="@drawable/ic_skip"
            app:tint="#FD272D"
            app:layout_constraintEnd_toStartOf="@id/btnSetupSkip"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnSetupSkip"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="16dp"
            android:text="@string/skipButton"
            android:textColor="#FD272D"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>