<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer base: sfondo scuro semi-trasparente -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#55101010" />
            <corners android:radius="40dp" />
        </shape>
    </item>

    <!-- Layer bordo luminoso stile glass (highlight superiore) -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="0.8dp"
                android:color="#33FFFFFF" />
            <corners android:radius="40dp" />
        </shape>
    </item>

</layer-list>